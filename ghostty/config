# Ghostty Configuration - r12f

# Font
font-family = JetBrains Mono
font-size = 14
font-thicken = true

# Theme
theme = Catppuccin Mocha

# Window
window-padding-x = 8
window-padding-y = 4
window-decoration = true
macos-titlebar-style = tabs
macos-option-as-alt = true
window-save-state = always

# Cursor
cursor-style = block
cursor-style-blink = false
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo

# Scrollback
scrollback-limit = 100000

# Mouse
copy-on-select = clipboard
mouse-hide-while-typing = true

# =============================================
# Keybindings (Cmd-based to avoid zellij conflicts)
# Zellij uses: Alt+hjkl/arrows, Alt+1-9, Alt+t/w/q/f/z, Ctrl+g/h/o/b/s/t/p/n/q
# Ghostty uses: Cmd (Super) — intercepted before reaching terminal
# =============================================

# --- Tabs ---
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab
keybind = super+one=goto_tab:1
keybind = super+two=goto_tab:2
keybind = super+three=goto_tab:3
keybind = super+four=goto_tab:4
keybind = super+five=goto_tab:5
keybind = super+six=goto_tab:6
keybind = super+seven=goto_tab:7
keybind = super+eight=goto_tab:8
keybind = super+nine=goto_tab:9

# --- Split Panes ---
keybind = super+backslash=new_split:right
keybind = super+minus=new_split:down
keybind = super+shift+w=close_surface

# --- Navigate Panes ---
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom

# --- Resize Panes ---
keybind = super+ctrl+left=resize_split:left,10
keybind = super+ctrl+right=resize_split:right,10
keybind = super+ctrl+up=resize_split:up,10
keybind = super+ctrl+down=resize_split:down,10

# --- Equalize Panes ---
keybind = super+shift+equal=equalize_splits

# --- Font Size ---
keybind = super+shift+plus=increase_font_size:1
keybind = super+shift+minus=decrease_font_size:1
keybind = super+zero=reset_font_size

# Misc
confirm-close-surface = false
auto-update = check
